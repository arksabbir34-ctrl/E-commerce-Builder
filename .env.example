# Database Configuration
# Set DATABASE_URL when deploying backend
DATABASE_URL=postgresql://user:password@host:port/database

# Frontend API Configuration
# Set VITE_API_URL on Netlify for cross-origin requests to separate backend
VITE_API_URL=https://your-backend-url.com

# Node Environment
NODE_ENV=production

# Session Secret (used for Express sessions if needed)
SESSION_SECRET=your-secret-key-here
